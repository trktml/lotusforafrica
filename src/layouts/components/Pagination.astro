---
import type { Page } from 'astro';
interface Props{
    page:Page,
    type:string
}
const {page,type} = Astro.props;
let pageCount = Math.ceil(page.total / page.size);

const getPages = (current: number, total: number) => {
    if (total <= 7) {
        return Array.from({ length: total }, (_, i) => i + 1);
    }

    if (current <= 4) {
        return [1, 2, 3, 4, 5, '...', total];
    }

    if (current >= total - 3) {
        return [1, '...', total - 4, total - 3, total - 2, total - 1, total];
    }

    return [1, '...', current - 1, current, current + 1, '...', total];
};

const pagesToDisplay = getPages(page.currentPage, pageCount);
---
<div class=`row align-items-center justify-content-center ${type==="start"?"flex-column":"flex-column-reverse"}`>
    <div class="col d-flex align-items-center justify-content-center">
        <nav aria-label="Wells page navigation">
            <ul class="pagination m-2 justify-content-center">
                <li class={`mx-1 page-item ${ page.url.prev ? '' : 'disabled' }`}>
                    <a style="font-size: 20px;" class="page-link" href={page.url.prev ? page.url.prev : "#"} aria-label="Previous page">
                        <span class="d-block" style="transform: rotate(180deg) translate(0px, -1px);">
                            <strong>&#10148;</strong>
                        </span>
                    </a>
                </li>
                <li class={`mx-1 page-item ${ page.url.next ? '' : 'disabled' }`}>
                    <a style="font-size: 20px;" class="page-link" href={page.url.next ? page.url.next : "#"} aria-label="Next page">
                        <span class="d-block" style="transform: translate(0px, -1px);">
                            <strong>&#10148;</strong>
                        </span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
    <div class="col d-flex align-items-center justify-content-center flex-wrap">
        {
            pagesToDisplay.map((p) => {
                if (p === '...') {
                    return <span style="margin:2px;" class="d-inline-block btn disabled btn-light align-self-center">...</span>;
                }
                return (
                    <a
                        style="margin:2px;"
                        class=`d-inline-block btn ${
                                p === page.currentPage
                                    ? 'btn-secondary'
                                    : 'btn-light'
                            }`
                        href={
                                page.url.current
                                    .split('/')
                                    .slice(0, -2)
                                    .join('/') +
                                '/' +
                                p +
                                '/'
                            }
                    >
                        {p}
                    </a>
                );
            })
        }
    </div>
</div>